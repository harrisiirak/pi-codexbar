{
  "name": "pi-codexbar",
  "version": "1.0.0",
  "description": "Pi extension wrapper for CodexBar provider state and controls",
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "provider-mappings.json",
    "settings.json",
    "README.md"
  ],
  "scripts": {
    "test": "node --experimental-test-module-mocks --import tsx --test 'tests/**/*.test.ts'",
    "run": "node --import tsx src/index.ts"
  },
  "keywords": [
    "pi-extension",
    "codexbar",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harrisiirak/pi-codexbar.git"
  },
  "homepage": "https://github.com/harrisiirak/pi-codexbar#readme",
  "bugs": {
    "url": "https://github.com/harrisiirak/pi-codexbar/issues"
  },
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.49"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.67.0",
    "@mariozechner/pi-ai": ">=0.67.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0"
  }
}
